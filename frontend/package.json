{
	"name": "grapheditor-frontend",
	"version": "0.0.0",
	"private": true,
	"author": "Mihajlo Lazar, Stefan Seliger",
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"engines": {
		"node": "22.20.0",
		"npm": "10.9.3"
	},
	"scripts": {
		"create-component": "node scripts/create-component.js",
		"dev": "npm run generate-build-info && vite",
		"build": "npm run generate-build-info && tsc && vite build",
		"test": "npm run test:unit",
		"test:unit": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:report": "playwright show-report",
		"preview": "vite preview --port 8080",
		"lint": "eslint src --ext .ts --ext .tsx",
		"lint:fix": "eslint src --ext .ts --ext .tsx --fix",
		"prettier:fix": "prettier --write src",
		"dependencies:check": "ncu --peer",
		"dependencies:update": "ncu --peer --upgrade",
		"generate-icon-font": "node ./scripts/generate-icon-font.js",
		"generate-build-info": "node ./scripts/generate-build-info.js",
		"setup": "npm install && allow-scripts",
		"setup:ci": "npm ci && allow-scripts"
	},
	"dependencies": {
		"@db-ux/react-core-components": "4.7.2",
		"@floating-ui/react": "^0.27.19",
		"@sigma/edge-curve": "^3.1.0",
		"@sigma/node-border": "^3.0.0",
		"@sigma/node-square": "^3.0.0",
		"@sigma/utils": "^3.0.0",
		"axios": "^1.16.0",
		"clsx": "^2.1.1",
		"graphology": "^0.26.0",
		"graphology-layout": "^0.6.1",
		"graphology-layout-force": "^0.2.4",
		"graphology-layout-forceatlas2": "^0.10.1",
		"graphology-layout-noverlap": "^0.4.2",
		"i18next": "^26.0.10",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-http-backend": "^4.0.0",
		"jsdom": "^29.1.1",
		"lucide-react": "^1.14.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-hook-form": "^7.75.0",
		"react-i18next": "^17.0.7",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.15.0",
		"seedrandom": "^3.0.5",
		"sigma": "^3.0.3",
		"source-map-js": "^1.2.1",
		"yup": "^1.7.1",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@cyclonedx/cyclonedx-npm": "^4.2.1",
		"@db-ux/icon-font-tools": "^0.3.6",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.59.1",
		"@lavamoat/allow-scripts": "^5.0.1",
		"@lavamoat/preinstall-always-fail": "^3.0.0",
		"@types/hoist-non-react-statics": "^3.3.7",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/react-router-dom": "^5.3.3",
		"@types/seedrandom": "^3.0.8",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.59.2",
		"@typescript-eslint/parser": "^8.59.2",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.5",
		"@vitest/browser-playwright": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"autoprefixer": "^10.5.0",
		"eslint": "^9.39.4",
		"dotenv": "^17.4.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-config-xo": "^0.49.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"globals": "^17.6.0",
		"license-compliance": "^3.0.1",
		"lucide-static": "^1.14.0",
		"msw": "^2.14.5",
		"npm-check-updates": "^22.1.1",
		"playwright": "1.59.1",
		"playwright-chromium": "1.59.1",
		"postcss": "^8.5.14",
		"prettier": "^3.8.3",
		"sass": "^1.99.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.11",
		"vite-plugin-checker": "^0.13.0",
		"vite-plugin-svgr": "^5.2.0",
		"vitest": "^4.1.5",
		"vitest-browser-react": "^2.2.0"
	},
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": true
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"lavamoat": {
		"allowScripts": {
			"@lavamoat/preinstall-always-fail": false,
			"@cyclonedx/cyclonedx-npm>libxmljs2#0.37.0": true,
			"@db-ux/icon-font-tools>svgtofont>ttf2woff2#8.0.1": true,
			"msw#2.14.5": true,
			"playwright-chromium#1.59.1": true,
			"sass>@parcel/watcher#2.5.6": true,
			"vite>esbuild#0.28.0": true,
			"@db-ux/icon-font-tools>esbuild#0.25.11": true
		}
	}
}
